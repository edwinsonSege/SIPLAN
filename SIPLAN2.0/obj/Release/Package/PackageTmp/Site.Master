       <style>
            body {
	/*margin: 0;
	padding: 0;
	font-family: Helvetica, Arial, sans-serif;*/
	/*color: #666;*/
	background: #f2f2f2; 
	/*font-size: 1em;
	line-height: 1.5em;*/
}


        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }        
        header{
            position:relative;
            background-color:#023a5f;
            color:white;
            width:100%;
            height:100px;            
            display:flex;
            align-items:center;
        }
        header p{
            width:100%;
            display:block;
            text-align:center;
            font-size:55px;
        }
        header p span{
            width:100%;
            display:block;
            text-align:center;
            font-size:30px;
            line-height:5px;
        }
        header #logout{
            position:absolute;
            right:10px;
        }
        header #lblUsuario{
            position:absolute;
            right:10px;
            top:80px;
            color:white;
        }
        header img{
            position:absolute;
            /*left: 10px;*/
            /*width:9%;*/
            width:350px;
            height:100%;
            /*background-color: #a4d2e0;*/            
        }
        main{
            display:flex;
            /*min-height:100vh;*/
        }
        main aside{
            background-color:transparent;
            width:0px;
            height:79vh;
        }
        main article{
            background-color:transparent;
            width:100%;
            height:79vh;
            z-index:1;
        }
        

        @media (min-width: 480px) and (max-width: 767px) {
            header p{
                width:100%;
                display:block;
                text-align:center;
                font-size:28px;
            }

            header p span{
                width:100%;
                display:block;
                text-align:center;
                font-size:17px !important;
                line-height:5px;
            }

            header img{
                position:absolute;
                width:120px;
                height:70px;
                /*left: 10px;*/
                /*width:9%;*/
                /*background-color: #a4d2e0;*/
                
            }

            header #logout{
                position:absolute;
                right:10px;
                font-size:14px;
            }
            header #lblUsuario{
                position:absolute;
                right:10px;
                top:80px;
                color:white;
                font-size:12px;
            }
        }

        @media (max-width: 479px){
           header{
		    height:50%;
	        }
            header p{
                width:100%;
                display:block;
                text-align:center;
                font-size:20px;
		        margin-left:-15px;
            }

            header p span{
                width:100%;
                display:block;
                text-align:center;
                font-size:15px;
                line-height:5px;
            }

            header img{
                position:absolute;
                width:20%;
		        height:100%;
		        left:0;		
		        top:50%;            	
            	transform:translateX(0px) translateY(-50%);
                /*left: 10px;*/
                /*width:9%;*/
                /*background-color: #a4d2e0;*/            
            }

            header #logout{
                position:absolute;                
		        top:50%;            	
            	transform:translateX(8%) translateY(-50%);
                font-size:11px;
            }
            header #lblUsuario{
                position:absolute;
                right:10px;
                top:80px;
                color:white;
                font-size:12px;
            }
        }
        #main-content {
	background: white;
	width: 90%;
	max-width: 800px;
	margin: 800px auto;
	box-shadow: 0 0 10px rgba(0,0,0,.1);
}

	#main-content header,
	#main-content .content {
		padding: 40px;
	}

    #main-footer {
	background-color:#023a5f;
	color: white;
	text-align: center;
	padding: 20px;
	margin-top: 40px;
    position:fixed;
}
	#main-footer p {
		margin: 0;
	}
	
	#main-footer a {
		color: white;
	}

   
     
        div .productHeader{
            display:flex;
            /*justify-content:flex-end;*/
            align-items:center;
        }
    </style>

</head>
<body>
    <form id="form1" runat="server">
        <asp:ScriptManager ID="ScriptManager1" runat="server"></asp:ScriptManager>
       <header>
            <%--<p>Sistema de Planes<span>SIPLAN</span></p> --%>     
           <p>Sistema de Planes<span>SIPLAN</span></p>      
           
