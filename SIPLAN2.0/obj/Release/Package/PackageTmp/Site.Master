           <a href="~/Documentos/Oficio_circular_SPPD-DASP-01-2024_Ejecución cuatrimestral_2024_Instituciones.pdf" runat="server" id="manualrepro" title="Registro de planificación, programación y ejecución cuatrimestral en el año 2024"><img src="../images/manualReprogramaciones.png"  style="float:right; width:50px; height:50px; right:15%; top:26px;   padding:7px;"/></a>     
