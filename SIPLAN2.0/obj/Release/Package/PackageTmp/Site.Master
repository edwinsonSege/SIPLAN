           <asp:ImageButton ID="informacion_usuariosss" ImageUrl="~/images/red_information.png"  AlternateText="No Image available" ToolTip="¡ATENCIÓN USUARIOS!" OnClick="atencionUsuario_Click" runat="server" style="width:35px;height:35px;position:absolute;right:18%;"/> 
          
           <a href="~/login/reset" runat="server" id="reset" title="Cambiar contraseña"><img src="../images/cambioContrasenia.png"  style="float:right; width:33px; height:33px; right:10%; top:33px; background: #a4d2e0; border-radius:50% 50%; padding:7px;"/></a>
            <%--</a>   --%>                   
            <%--</a>   --%>                   
        </header>
        <main>
            <aside>
            
            </aside>
            <article>            
                <div>
                      <asp:ContentPlaceHolder runat="server" ID="MainContent"                       
                          
                          />
                      
                    <dx:ASPxPopupControl ID="popDocumento" runat="server" AllowDragging ="true" Width ="1600px" Height="700px" HeaderText="Información importante,procesos para solicitud de nuevos usuarios y reinicio de contraseña" PopupHorizontalAlign="WindowCenter"  PopupVerticalAlign="WindowCenter"  CloseAction="CloseButton"  >
                                <HeaderStyle Font-Bold="False" Font-Size="10"  HorizontalAlign="Left" />
